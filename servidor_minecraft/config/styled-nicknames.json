{
  "CONFIG_VERSION_DONT_TOUCH_THIS": 1,
  "_comment": "Before changing anything, see https://github.com/Patbox/StyledNicknames#configuration",
  "allowByDefault": true,
  "nicknameFormat": "${nickname}",
  "maxLength": 48,
  "changeDisplayName": true,
  "changePlayerListName": true,
  "allowLegacyFormatting": false,
  "nicknameChangedMessage": "<bold><gradient:#55FFFF:#0055FF>Atlas Adventure</gradient></bold> <dark_gray>»</dark_gray> <gray>Tu apodo ahora es:</gray> ${nickname}",
  "nicknameResetMessage": "<bold><gradient:#55FFFF:#0055FF>Atlas Adventure</gradient></bold> <dark_gray>»</dark_gray> <gray>¡Tu apodo ha sido restablecido!</gray>",
  "defaultEnabledFormatting": {
    "dark_red": true,
    "color": true,
    "underline": true,
    "yellow": true,
    "hard_gradient": true,
    "italic": true,
    "dark_blue": true,
    "dark_purple": true,
    "gold": true,
    "red": true,
    "aqua": true,
    "hover": false,
    "gray": true,
    "light_purple": true,
    "white": true,
    "dark_gray": true,
    "strikethrough": true,
    "obfuscated": false,
    "change_page": false,
    "green": true,
    "dark_green": true,
    "gradient": true,
    "black": false,
    "bold": true,
    "rainbow": true,
    "blue": true,
    "dark_aqua": true,
    "reset": true
  },
  "tooLongMessage": "<red>¡Ese apodo es demasiado largo!</red>"
}